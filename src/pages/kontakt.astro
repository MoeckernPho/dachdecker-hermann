---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import ContactForm from "../components/ContactForm.astro";
import GoogleMap from "../components/GoogleMap.astro";
import { Phone, Mail, MapPin, Clock } from "@lucide/astro";
import { nap, openingHours } from "../data/site";

const title = "Kontakt & Anfrage | Dachdecker Herrmann Rackwitz";
const description =
  "Kontakt zum Dachdeckermeisterbetrieb André Herrmann in Rackwitz: Schreiben Sie uns über das " +
  "Formular oder rufen Sie an. Wir melden uns zeitnah mit einer ehrlichen Einschätzung.";
---

<BaseLayout title={title} description={description}>
  <PageHeader
    eyebrow="Kontakt"
    title="Anfrage senden. Wir melden uns"
    lead="Beschreiben Sie kurz Ihr Vorhaben. Sie erhalten eine ehrliche Einschätzung und ein faires Angebot. Lieber telefonisch? Rufen Sie einfach an."
  />

  <section class="bg-brand-surface py-16 sm:py-20">
    <div class="container-site grid gap-10 lg:grid-cols-[1.2fr_0.8fr] lg:gap-14">
      {/* Formular */}
      <div class="card p-6 sm:p-8">
        <h2 class="text-2xl">Ihre Nachricht an uns</h2>
        <p class="mt-2 text-sm text-brand-muted">
          Felder mit <span class="text-brand-accent">*</span> sind Pflichtfelder.
        </p>
        <div class="mt-6">
          <ContactForm />
        </div>
      </div>

      {/* Kontaktinfos / NAP */}
      <aside class="space-y-6">
        <div class="card p-6">
          <h2 class="text-xl">Direkt erreichen</h2>
          <ul class="mt-5 space-y-4 text-sm">
            <li class="flex items-start gap-3">
              <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-btn bg-brand-ink text-brand-ember">
                <Phone size={20} stroke-width={1.75} aria-hidden="true" />
              </span>
              <span>
                <span class="block font-display font-bold text-brand-ink">Telefon</span>
                <a href={nap.phoneHref} class="text-brand-accent hover:text-brand-accent-strong">
                  {nap.phoneDisplay}
                </a>
              </span>
            </li>
            <li class="flex items-start gap-3">
              <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-btn bg-brand-ink text-brand-ember">
                <Mail size={20} stroke-width={1.75} aria-hidden="true" />
              </span>
              <span class="min-w-0">
                <span class="block font-display font-bold text-brand-ink">E-Mail</span>
                <a href={nap.emailHref} class="break-all text-brand-accent hover:text-brand-accent-strong">
                  {nap.email}
                </a>
              </span>
            </li>
            <li class="flex items-start gap-3">
              <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-btn bg-brand-ink text-brand-ember">
                <MapPin size={20} stroke-width={1.75} aria-hidden="true" />
              </span>
              <span>
                <span class="block font-display font-bold text-brand-ink">Adresse</span>
                <address class="not-italic text-brand-muted">
                  {nap.company}<br />
                  {nap.street}<br />
                  {nap.postalCode}&nbsp;{nap.city}
                </address>
              </span>
            </li>
          </ul>
        </div>

        <div class="card p-6">
          <h2 class="flex items-center gap-2 text-xl">
            <Clock size={20} stroke-width={1.75} aria-hidden="true" class="text-brand-accent" />
            Öffnungszeiten
          </h2>
          <ul class="mt-4 space-y-2 text-sm">
            {
              openingHours.display.map((row) => (
                <li class="flex justify-between gap-4 border-b border-brand-border pb-2 last:border-0 last:pb-0">
                  <span class="text-brand-muted">{row.days}</span>
                  <span class="font-semibold text-brand-ink">{row.hours}</span>
                </li>
              ))
            }
          </ul>
          <p class="mt-3 text-xs text-brand-muted">Öffnungszeiten vorläufig, bitte bestätigen.</p>
        </div>
      </aside>
    </div>
  </section>

  <GoogleMap />
</BaseLayout>
