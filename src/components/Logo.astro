---
import { nap } from "../data/site";

interface Props {
  tone?: "light" | "dark";
  size?: "default" | "header";
  class?: string;
}
const { tone = "light", size = "default", class: className = "" } = Astro.props;
const imageSize =
  size === "header" ? "h-20 md:h-24" : "h-12 md:h-14";
---

<span class={`inline-flex ${className}`} data-tone={tone}>
  <img
    src="/images/logo.png"
    alt={nap.company}
    width="214"
    height="121"
    class={`w-auto max-w-none object-contain ${imageSize}`}
  />
</span>
