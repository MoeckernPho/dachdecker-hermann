---
interface Props {
  eyebrow: string;
  title: string;
  lead?: string;
}
const { eyebrow, title, lead } = Astro.props;
---

<section class="slate-texture text-white">
  <div class="container-site py-14 sm:py-16 lg:py-20">
    <p class="eyebrow text-brand-ember">
      <span class="inline-block h-px w-8 bg-brand-ember"></span>
      {eyebrow}
    </p>
    <h1 class="mt-4 max-w-3xl text-4xl sm:text-5xl">{title}</h1>
    {lead && <p class="mt-5 max-w-2xl text-lg text-brand-slate-muted">{lead}</p>}
  </div>
</section>
