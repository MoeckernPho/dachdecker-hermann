# ENV-Vorlage — Dachdecker-Hermann
# KEINE echten Secrets committen. Werte auf Scalingo via Dashboard / `scalingo env-set` setzen.

# --- SMTP (Mailversand Kontaktformular) ---
SMTP_HOST=smtp.example.de
SMTP_PORT=587
# true = SMTPS/465 (implizites TLS); false = 587/STARTTLS
SMTP_SECURE=false
SMTP_USER=info@Dachdecker-Hermann.de
SMTP_PASS=changeme

# --- Mail-Adressen ---
# Empfänger der Formularanfragen
MAIL_TO=info@Dachdecker-Hermann.de
# Absenderadresse (muss vom SMTP-Anbieter erlaubt sein)
MAIL_FROM=info@Dachdecker-Hermann.de

# --- Optional ---
# Überschreibt die Domain für absolute Links/Canonicals (sonst astro.config `site`)
PUBLIC_SITE_URL=https://www.dachdecker-hermann.de
